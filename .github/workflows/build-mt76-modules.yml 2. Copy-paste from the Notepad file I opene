name: Build MT76 WiFi Modules (MT7921AU)

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-24.04

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison build-essential flex libelf-dev libssl-dev rsync python3 python3-pip git wget libdw-dev zip dwarves gcc-aarch64-linux-gnu binutils-aarch64-linux-gnu lld

      - name: Install Rust 1.82.0 and bindgen
        run: |
          curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.82.0 --component rust-src
          source "$HOME/.cargo/env"
          rustup component add rust-src
          cargo install --locked bindgen-cli@0.69.5
          echo "$HOME/.cargo/bin" >> "$GITHUB_PATH"

      - name: Download Clang Compiler (r547379)
        run: |
          git clone -b llvm-r547379-release --depth 1 --sparse --filter=blob:none https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86 clang-bin
          cd clang-bin
          git sparse-checkout set clang-r547379
          mv clang-r547379 ..
          cd ..
          rm -rf clang-bin

      - name: Enable MT76 Configs in Defconfig
        run: |
          DEFCONFIG="kernel_platform/common/arch/arm64/configs/nx809j_defconfig"
          cat >> "$DEFCONFIG" << 'EOF'

          # ============================================
          # Wireless base stack
          # ============================================
          CONFIG_CFG80211=m
          CONFIG_CFG80211_DEFAULT_PS=y
          CONFIG_CFG80211_WEXT=y
          CONFIG_MAC80211=m

          # ============================================
          # MediaTek MT76 - Vendor + Core
          # ============================================
          CONFIG_WLAN_VENDOR_MEDIATEK=y
          CONFIG_MT76_CORE=m
          CONFIG_MT76_USB=m
          CONFIG_MT76_SDIO=m
          CONFIG_MT76_LEDS=y
          CONFIG_MT76x02_LIB=m
          CONFIG_MT76x02_USB=m
          CONFIG_MT76_CONNAC_LIB=m
          CONFIG_MT792x_LIB=m
          CONFIG_MT792x_USB=m

          # MT7601U
          CONFIG_MT7601U=m

          # MT76x0 family
          CONFIG_MT76x0_COMMON=m
          CONFIG_MT76x0U=m
          CONFIG_MT76x0E=m

          # MT76x2 family
          CONFIG_MT76x2_COMMON=m
          CONFIG_MT76x2E=m
          CONFIG_MT76x2U=m

          # MT7603
          CONFIG_MT7603E=m

          # MT7615 family
          CONFIG_MT7615_COMMON=m
          CONFIG_MT7615E=m
          CONFIG_MT7663_USB_SDIO_COMMON=m
          CONFIG_MT7663U=m
          CONFIG_MT7663S=m

          # MT7915
          CONFIG_MT7915E=m

          # MT7921 family
          CONFIG_MT7921_COMMON=m
          CONFIG_MT7921E=m
          CONFIG_MT7921S=m
          CONFIG_MT7921U=m

          # MT7925 family (Wi-Fi 7)
          CONFIG_MT7925_COMMON=m
          CONFIG_MT7925E=m
          CONFIG_MT7925U=m

          # MT7996 (Wi-Fi 7)
          CONFIG_MT7996E=m

          # ============================================
          # Realtek - RTW88 (802.11ac)
          # ============================================
          CONFIG_RTW88=m
          CONFIG_RTW88_CORE=m
          CONFIG_RTW88_PCI=m
          CONFIG_RTW88_SDIO=m
          CONFIG_RTW88_USB=m
          CONFIG_RTW88_8822B=m
          CONFIG_RTW88_8822C=m
          CONFIG_RTW88_8723X=m
          CONFIG_RTW88_8703B=m
          CONFIG_RTW88_8723D=m
          CONFIG_RTW88_8821C=m
          CONFIG_RTW88_8822BE=m
          CONFIG_RTW88_8822BS=m
          CONFIG_RTW88_8822BU=m
          CONFIG_RTW88_8822CE=m
          CONFIG_RTW88_8822CS=m
          CONFIG_RTW88_8822CU=m
          CONFIG_RTW88_8723DE=m
          CONFIG_RTW88_8723DS=m
          CONFIG_RTW88_8723CS=m
          CONFIG_RTW88_8723DU=m
          CONFIG_RTW88_8821CE=m
          CONFIG_RTW88_8821CS=m
          CONFIG_RTW88_8821CU=m
          EOF

      - name: Compile Kernel + WiFi Modules
        run: |
          export PATH="$HOME/.cargo/bin:$PATH"
          export CLANG_DIR="$(pwd)/clang-r547379"
          export PATH="$CLANG_DIR/bin:$PATH"
          export ARCH=arm64
          export SUBARCH=arm64
          export CROSS_COMPILE=aarch64-linux-gnu-
          export CROSS_COMPILE_ARM32=arm-linux-gnueabi-
          export CLANG_TRIPLE=aarch64-linux-gnu-
          export CC=clang

          cd kernel_platform/common

          # Generate .config with MT76 options
          make LLVM=1 LLVM_IAS=1 nx809j_defconfig
          make LLVM=1 LLVM_IAS=1 olddefconfig

          # Build full kernel (needed for Module.symvers)
          make -j$(nproc) LLVM=1 LLVM_IAS=1 KBUILD_MODPOST_WARN=1 Image modules

      - name: Collect WiFi Module Files
        run: |
          KERNEL_DIR="kernel_platform/common"
          OUT_DIR="mt76-modules"
          mkdir -p "$OUT_DIR"

          echo "=== Searching for built WiFi modules ==="

          # MT76 core modules
          for mod in \
            drivers/net/wireless/mediatek/mt76/mt76.ko \
            drivers/net/wireless/mediatek/mt76/mt76-usb.ko \
            drivers/net/wireless/mediatek/mt76/mt76-connac-lib.ko \
            drivers/net/wireless/mediatek/mt76/mt792x-lib.ko \
            drivers/net/wireless/mediatek/mt76/mt792x-usb.ko \
            drivers/net/wireless/mediatek/mt76/mt7921/mt7921-common.ko \
            drivers/net/wireless/mediatek/mt76/mt7921/mt7921u.ko \
            drivers/net/wireless/mediatek/mt76/mt76x2/mt76x2-common.ko \
            drivers/net/wireless/mediatek/mt76/mt76x2/mt76x2u.ko \
            drivers/net/wireless/mediatek/mt7601u/mt7601u.ko; do
            if [ -f "$KERNEL_DIR/$mod" ]; then
              cp "$KERNEL_DIR/$mod" "$OUT_DIR/"
              echo "  ✓ $(basename $mod)"
            else
              echo "  ✗ $(basename $mod) - not built"
            fi
          done

          # RTW88 modules
          for mod in \
            drivers/net/wireless/realtek/rtw88/rtw88_core.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_usb.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_pci.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_sdio.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_8822bu.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_8822b.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_8822c.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_8822cu.ko \
            drivers/net/wireless/realtek/rtw88/rtw88_8821cu.ko; do
            if [ -f "$KERNEL_DIR/$mod" ]; then
              cp "$KERNEL_DIR/$mod" "$OUT_DIR/"
              echo "  ✓ $(basename $mod)"
            else
              echo "  ✗ $(basename $mod) - not built"
            fi
          done

          echo ""
          echo "=== Collected modules ==="
          ls -la "$OUT_DIR/"
          echo ""
          echo "Total: $(ls "$OUT_DIR/"*.ko 2>/dev/null | wc -l) modules"

      - name: Create KernelSU Module Zip
        run: |
          MODULE_DIR="wifi-firmware-module"
          mkdir -p "$MODULE_DIR/lib/firmware/mediatek"
          mkdir -p "$MODULE_DIR/lib/firmware/rtw88"

          # Copy firmware files
          cp mt76-modules/*.ko "$MODULE_DIR/lib/firmware/" 2>/dev/null || true

          # Copy firmware binaries (will be downloaded separately)
          cat > "$MODULE_DIR/module.prop" << 'EOF'
          id=wifi-drivers-firmware
          name=WiFi Drivers + Firmware (MT76 + RTW88)
          version=1.0
          versionCode=1
          author=user
          description=MT7921AU + MT7612U + RTL8822BU USB WiFi drivers and firmware
          EOF

          cat > "$MODULE_DIR/post-fs-data.sh" << 'SCRIPT'
          #!/bin/sh
          # Load MT76 modules in dependency order
          MODDIR=/vendor_dlkm/lib/modules
          FWDIR=/vendor/firmware

          insmod $MODDIR/mt76.ko
          insmod $MODDIR/mt76-usb.ko
          insmod $MODDIR/mt76-connac-lib.ko
          insmod $MODDIR/mt792x-lib.ko
          insmod $MODDIR/mt792x-usb.ko
          insmod $MODDIR/mt7921-common.ko
          insmod $MODDIR/mt7921u.ko
          SCRIPT
          chmod 755 "$MODULE_DIR/post-fs-data.sh"

          zip -r wifi-drivers-firmware.zip "$MODULE_DIR/"

      - name: Upload WiFi Modules
        uses: actions/upload-artifact@v4
        with:
          name: mt76-rtw88-modules
          path: mt76-modules/*.ko

      - name: Upload KernelSU Module Zip
        uses: actions/upload-artifact@v4
        with:
          name: wifi-drivers-firmware-module
          path: wifi-drivers-firmware.zip
